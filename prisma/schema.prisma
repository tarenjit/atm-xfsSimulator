// ============================================================================
// ATM XFS Simulator — Prisma Schema
// PostgreSQL. All monetary amounts are BigInt (IDR has no minor units but can
// exceed 32-bit range). All timestamps are UTC.
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Account & card
// ----------------------------------------------------------------------------

model Account {
  id             String   @id @default(cuid())
  accountNumber  String   @unique
  holderName     String
  balance        BigInt
  currency       String   @default("IDR")
  dailyLimit     BigInt   @default(10000000)
  dailyWithdrawn BigInt   @default(0)
  status         String   @default("ACTIVE") // ACTIVE, BLOCKED, CLOSED
  cards          VirtualCard[]
  transactions   Transaction[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([accountNumber])
  @@index([status])
}

model VirtualCard {
  pan            String   @id
  cardholderName String
  expiryDate     String   // YYMM
  pin            String   // simulator-only; stored as salted SHA-256 via @atm/shared hashPin()
  track1         String
  track2         String
  issuer         String   @default("ZEGEN")
  status         String   @default("ACTIVE") // ACTIVE, BLOCKED, EXPIRED, RETAINED
  failedPinCount Int      @default(0)
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([accountId])
}

// ----------------------------------------------------------------------------
// Transactions
// ----------------------------------------------------------------------------

model Transaction {
  id           String   @id @default(cuid())
  sessionId    String
  pan          String
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id])
  txnType      String   // WITHDRAWAL, BALANCE, TRANSFER, DEPOSIT
  amount       BigInt
  currency     String   @default("IDR")
  status       String   // PENDING, COMPLETED, FAILED, REVERSED
  stanNo       String?
  authCode     String?
  responseCode String?
  errorReason  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([pan])
  @@index([sessionId])
  @@index([createdAt])
  @@index([status])
  // Hot path for the daily-withdrawal-limit check in Phase 3.
  @@index([accountId, status, createdAt])
}

// ----------------------------------------------------------------------------
// XFS command + event logs
// ----------------------------------------------------------------------------

model XfsCommandLog {
  id           String   @id @default(cuid())
  sessionId    String?
  hService     String
  serviceClass String
  commandCode  String
  requestId    String
  payload      Json
  response     Json?
  result       Int?
  errorDetail  String?
  durationMs   Int?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([commandCode])
  @@index([createdAt])
}

model XfsEventLog {
  id           String   @id @default(cuid())
  sessionId    String?
  hService     String
  serviceClass String
  eventCode    String
  eventClass   String
  payload      Json
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([eventCode])
  @@index([createdAt])
}

// ----------------------------------------------------------------------------
// CDM cassette state (persisted snapshot; runtime truth lives in the service)
// ----------------------------------------------------------------------------

model CashUnit {
  id           String   @id @default(cuid())
  unitId       String   @unique
  denomination Int
  currency     String   @default("IDR")
  status       String   @default("OK")
  count        Int
  initialCount Int
  maximum      Int
  minimum      Int
  rejectCount  Int      @default(0)
  updatedAt    DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// ATM session history (for replay)
// ----------------------------------------------------------------------------

model AtmSession {
  id         String   @id
  state      String
  pan        String?
  accountId  String?
  startedAt  DateTime @default(now())
  endedAt    DateTime?
  endReason  String?  // COMPLETED, CANCELLED, TIMEOUT, ERROR

  @@index([pan])
  @@index([startedAt])
}

// ----------------------------------------------------------------------------
// Bank theme (Update_features.md §8)
// ----------------------------------------------------------------------------

model BankTheme {
  id              String   @id @default(cuid())
  code            String   @unique   // "mandiri", "bsi", "btn", "bni", "bri", "bca"
  name            String              // "Bank Mandiri"
  logoUrl         String?             // /themes/mandiri/logo.svg
  primaryColor   String               // hex, e.g. "#003D79"
  secondaryColor String
  accentColor    String
  defaultLanguage String  @default("id")
  receiptTemplate String              // Handlebars-ish receipt template
  isDefault      Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// Macro Test Studio (Update_features.md §4)
// ----------------------------------------------------------------------------

model Macro {
  id          String     @id @default(cuid())
  name        String
  folder      String?    // e.g. "Logins", "Withdrawals"
  description String?
  tags        String[]   @default([])
  steps       Json       // MacroStep[]
  variables   Json       @default("{}")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  runs        MacroRun[]

  @@index([folder])
  @@index([name])
}

model MacroRun {
  id          String    @id @default(cuid())
  macroId     String
  macro       Macro     @relation(fields: [macroId], references: [id], onDelete: Cascade)
  status      String    // RUNNING, PASSED, FAILED, ABORTED
  currentStep Int?
  stepResults Json      @default("[]")
  evidence    Json?     // { screenshots, commandLog, receipts }
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?
  suiteRunId  String?
  suiteRun    MacroSuiteRun? @relation(fields: [suiteRunId], references: [id], onDelete: SetNull)

  @@index([macroId])
  @@index([status])
  @@index([startedAt])
  @@index([suiteRunId])
}

model MacroSuite {
  id         String            @id @default(cuid())
  name       String            @unique
  macroIds   String[]          @default([])
  cron       String?           // standard 5-field cron, null = on-demand only
  enabled    Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  runs       MacroSuiteRun[]

  @@index([enabled])
}

model MacroSuiteRun {
  id          String     @id @default(cuid())
  suiteId     String
  suite       MacroSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  status      String     // RUNNING, PASSED, FAILED, ABORTED
  triggeredBy String     // CRON, MANUAL
  startedAt   DateTime   @default(now())
  completedAt DateTime?
  durationMs  Int?
  macroRuns   MacroRun[]

  @@index([suiteId])
  @@index([status])
  @@index([startedAt])
}

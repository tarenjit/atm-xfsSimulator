# ============================================================================
# ATM XFS Simulator — Environment Variables
# Copy to .env and fill in values for local development.
# ============================================================================

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
# Install Postgres locally: brew install postgresql@16 && brew services start postgresql@16
# Then: createdb atm_simulator
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atm_simulator?schema=public"

# ----------------------------------------------------------------------------
# Redis (BullMQ) — optional for Phase 1, required Phase 2+
# ----------------------------------------------------------------------------
# Install: brew install redis && brew services start redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------------------------
# Backend (NestJS xfs-server)
# ----------------------------------------------------------------------------
XFS_SERVER_PORT=3001
XFS_SERVER_HOST=0.0.0.0
NODE_ENV=development

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug
# Pretty-print pino logs in development (false for JSON production logs)
LOG_PRETTY=true
# Log file destination (empty = stdout only)
LOG_FILE=logs/xfs-server.log

# ----------------------------------------------------------------------------
# Frontend (Next.js atm-frontend)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# CORS — comma-separated origins allowed to connect to the XFS server
# ----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# ATM Branding
# ----------------------------------------------------------------------------
ATM_BANK_NAME=Bank Zegen
ATM_TERMINAL_ID=ZGN-001

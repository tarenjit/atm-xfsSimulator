{
  "name": "atm-xfs-simulator",
  "version": "0.1.0",
  "private": true,
  "description": "Virtual ATM Simulator with XFS Device Emulation Layer (PT Zegen Solusi Mandiri)",
  "scripts": {
    "dev": "turbo run dev",
    "serve": "turbo run serve --filter=@atm/atm-frontend --filter=@atm/xfs-server",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "pnpm --filter prisma-workspace prisma generate --schema=../prisma/schema.prisma || prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma --force",
    "db:seed": "tsx prisma/seed.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "codegen": "tsx generators/ts-codegen.ts && tsx generators/cpp-codegen.ts",
    "codegen:check": "tsx generators/ts-codegen.ts && tsx generators/cpp-codegen.ts && git diff --exit-code packages/xfs-core/src/generated"
  },
  "dependencies": {
    "@atm/shared": "workspace:*",
    "@prisma/client": "^5.14.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "eslint": "^8.57.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.2.5",
    "prisma": "^5.14.0",
    "rimraf": "^5.0.10",
    "tsx": "^4.7.1",
    "turbo": "^2.0.3",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  }
}

{
  "name": "@atm/xfs-server",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS backend for the ATM XFS simulator: XFS manager, ATM app, host emulator.",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest build && nest start --watch --preserveWatchOutput",
    "start": "node dist/main.js",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "serve": "nest build && node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "clean": "rimraf dist .turbo coverage",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@atm/iso8583": "workspace:*",
    "@atm/shared": "workspace:*",
    "@atm/xfs-core": "workspace:*",
    "@atm/xfs-devices": "workspace:*",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.8",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/platform-socket.io": "^10.3.8",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/websockets": "^10.3.8",
    "@prisma/client": "^5.14.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.4.0",
    "nestjs-pino": "^4.0.0",
    "pdfkit": "^0.15.0",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "pino-pretty": "^11.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "cross-env": "^7.0.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
